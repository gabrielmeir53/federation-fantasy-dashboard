# ============================================================
# Federation Dashboard — Configuration
# ============================================================
# Copy this file to .env and fill in your values.
# These values are used by scrape_fantrax.py.
#
# HOW TO FIND YOUR LEAGUE ID:
#   1. Go to your Fantrax league page
#   2. Look at the URL: https://www.fantrax.com/fantasy/league/XXXXXXXXXXXXXXXX/home
#   3. The XXXXXXXXXXXXXXXX part is your league ID
#
# IMPORTANT: All leagues must be set to Public visibility
#   (Commissioner → League Setup → Misc → League Visibility: Public)
# ============================================================

# Fantrax League IDs (one per sport)
NFL_LEAGUE_ID=your_nfl_league_id_here
NBA_LEAGUE_ID=your_nba_league_id_here
NHL_LEAGUE_ID=your_nhl_league_id_here
MLB_LEAGUE_ID=your_mlb_league_id_here

# Previous NFL season league ID (for playoff bracket history)
# If your NFL league recreates each year, put last year's league ID here.
# If it's the same league, leave this the same as NFL_LEAGUE_ID.
NFL_PREV_LEAGUE_ID=your_previous_nfl_league_id_here

# Google Sheets IDs (optional — for draft picks and schedule metadata)
# Create a public Google Sheet and grab the ID from the URL:
#   https://docs.google.com/spreadsheets/d/SHEET_ID_HERE/edit
DRAFT_SHEET_ID=your_draft_sheet_id_here
SCHEDULE_SHEET_ID=your_schedule_sheet_id_here

# Current federation season
FEDERATION_SEASON=2025-26

# Draft pick seasons to scrape (comma-separated)
DRAFT_SEASONS=2026-27,2027-28,2028-29,2029-30,2030-31,2031-32,2032-33,2033-34

# Server deployment (only needed for cPanel deployment)
CPANEL_USERNAME=your_cpanel_username
DOMAIN_DIR=yourdomain.com
TRIGGER_SECRET=change_this_to_a_random_string
